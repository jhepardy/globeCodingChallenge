{
  "name": "shopsphere-spree-playwright",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright UI automation for the Spree Commerce demo store.",
  "scripts": {
    "test": "playwright test --project=chromium-desktop",
    "test:web": "playwright test --project=chromium-desktop",
    "test:mobile": "playwright test --project=chromium-mobile-sm",
    "test:tablet": "playwright test --project=chromium-tablet",
    "test:smoke": "playwright test tests/smoke --project=chromium-desktop",
    "test:smoke:web": "playwright test tests/smoke --project=chromium-desktop",
    "test:smoke:mobile": "playwright test tests/smoke --project=chromium-mobile-sm",
    "test:smoke:tablet": "playwright test tests/smoke --project=chromium-tablet",
    "test:smoke:all": "playwright test tests/smoke",
    "test:regression": "playwright test tests/regression --project=chromium-desktop",
    "test:regression:web": "playwright test tests/regression --project=chromium-desktop",
    "test:regression:mobile": "playwright test tests/regression --project=chromium-mobile-sm",
    "test:regression:tablet": "playwright test tests/regression --project=chromium-tablet",
    "test:regression:all": "playwright test tests/regression",
    "test:ci": "CI=1 playwright test tests/smoke --project=chromium-desktop",
    "test:ci:all": "CI=1 playwright test tests/smoke",
    "test:parallel": "playwright test tests/smoke --project=chromium-desktop --workers=2",
    "test:parallel:4": "playwright test tests/smoke --project=chromium-desktop --workers=4",
    "test:headed": "playwright test --headed --project=chromium-desktop",
    "test:ui": "playwright test --ui",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.9.1",
    "typescript": "^5.9.3"
  }
}
